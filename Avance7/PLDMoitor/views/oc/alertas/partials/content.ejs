<div class="main-content">
     <div class="header">
         <h2>Alertas</h2>
     </div>
     <div class="content">
         <div class="card">
             <div class="card-body">
                 <h3>Bienvenido, Oficial de Cumplimiento</h3>
                 <p>Desde aquí puedes gestionar tus alertas.</p>
             </div>
         </div>
     </div>

    <div class="alertas">
            <!-- Filtros para alertas -->
            <form id="alertas-filtro-form" style="margin-bottom: 1em; display: flex; gap: 1em; align-items: center;">
                <input type="text" id="alerta-search" name="search" placeholder="Buscar alerta..." value="<%= typeof search !== 'undefined' ? search : '' %>" style="padding: 0.5em; border-radius: 4px; border: 1px solid #ccc;" />
                <select id="alerta-status" name="status" style="padding: 0.5em; border-radius: 4px; border: 1px solid #ccc;">
                    <option value="" <%= !status ? 'selected' : '' %>>Todos los estatus</option>
                    <option value="abierta" <%= status === 'abierta' ? 'selected' : '' %>>Abierta</option>
                    <option value="en revision" <%= status === 'en revision' ? 'selected' : '' %>>En revisión</option>
                    <option value="cerrada" <%= status === 'cerrada' ? 'selected' : '' %>>Cerrada</option>
                </select>
            </form>
        <table border="1">
            <thead>
                <tr>
                    <th>ID Alerta</th>
                    <th>ID Cliente</th>
                    <th>ID Operación</th>
                    <th>Tipo</th>
                    <th>Motivo</th>
                    <th>Evidencia</th>
                    <th>Fecha Generación</th>
                    <th>Estatus</th>
                    <th>Fecha Cierre</th>
                </tr>
            </thead>
            <tbody>
                <% alertas.forEach(alerta => { %>
                    <tr>
                        <td><%= alerta.id_alerta %></td>
                        <td><%= alerta.cliente_id %></td>
                        <td><%= alerta.id_operacion %></td>
                        <td><%= alerta.tipo_alerta %></td>
                        <td><%= alerta.motivo %></td>
                        <td><%= alerta.evidencia_asociada %></td>
                        <td><%= alerta.fecha_generacion %></td>
                        <td><%= alerta.estatus %></td>
                        <td><%= alerta.fecha_cierre %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="pager">
            <div style="margin: 1em; margin-left: 0;"><p class="meta"><% if (alertas.length > 0) { %>Mostrando <%= alertas.length %> de <%= total %> alertas<% } else { %>No hay alertas disponibles<% } %></p></div>
            <% const filtroQuery = (search || status) ? `&search=${encodeURIComponent(search || '')}&status=${encodeURIComponent(status || '')}` : '';
            %>
            <% if (page > 1) { %>
                <a href="/oficial/Alertas?page=<%= page - 1 %><%= filtroQuery %>">← Anterior</a>
            <% } %>
            <% for (let p = 1; p <= totalPages; p++) { %>
                <% if (p === page) { %>
                    <span class="current"><%= p %></span>
                <% } else { %>
                    <a href="/oficial/Alertas?page=<%= p %><%= filtroQuery %>"><%= p %></a>
                <% } %>
            <% } %>
            <% if (page < totalPages) { %>
                <a href="/oficial/Alertas?page=<%= page + 1 %><%= filtroQuery %>">Siguiente →</a>
            <% } %>
        </div>
    <script src="/js/alertasFiltro.js"></script>
    </div>
 </div>