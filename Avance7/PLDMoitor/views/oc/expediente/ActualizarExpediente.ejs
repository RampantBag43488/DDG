
<!DOCTYPE HTML>
<html>
<head>
  <%- include('./partials/css') %>
</head>
<body>
  <%- include('./components/sidebar') %>
  <div class="main-content">
      <div class="page-top">
          <div>
              <h1>Actualizar Expediente</h1>
              <p class="subtitle">Modifica los datos del cliente. Cambia solo los campos necesarios.</p>
          </div>
          <form action="/oficial/Expediente" method="get">
              <button class="VolverButton" type="submit">
                  <div class="plus">
                      <i class="fa-solid fa-arrow-left"></i>
                  </div>
                  Volver
              </button>
          </form>
      </div>
      <section class="form-card">
          <form id="actualizarExpedienteForm" action="/oficial/Expediente/Actualizar" method="post">
              <input type="hidden" name="id_expediente" value="<%= expediente.id_expediente %>" />
              <input type="hidden" name="cliente_id" value="<%= expediente.cliente_id %>" />
              <div class="form-header">
                  <div>
                        <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
                            <div style="color: #fff; background: #e74c3c; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;">
                                <%= errorMessage %>
                            </div>
                        <% } %>
                      <h2>Datos del cliente</h2>
                      <p>Modifica los campos necesarios y haz clic en Actualizar.</p>
                  </div>
                  
                  <div class="field-group select-group">
                      <label for="tipoPersona">Tipo de Persona</label>
                      <select id="tipoPersona" name="tipo_persona" aria-label="Tipo de Persona" disabled>
                          <option value="fisica" <%= expediente.tipo_persona === 'fisica' ? 'selected' : '' %>>Persona Física</option>
                          <option value="moral" <%= expediente.tipo_persona === 'moral' ? 'selected' : '' %>>Persona Moral</option>
                      </select>
                      <input type="hidden" name="tipo_persona" value="<%= expediente.tipo_persona %>" />
                  </div>
              </div>
                    <div class="form-grid">
                        <!-- Datos comunes para ambos tipos -->
                        <div class="field-group">
                            <label for="nacionalidad">Nacionalidad</label>
                            <input id="nacionalidad" name="nacionalidad" type="text" value="<%= expediente.nacionalidad %>" required>
                        </div>
                        <div class="field-group">
                            <label for="telefono">Teléfono</label>
                            <input id="telefono" name="telefono" type="tel" value="<%= expediente.telefono %>" required>
                        </div>
                        <div class="field-group">
                            <label for="correo">Correo</label>
                            <input id="correo" name="correo" type="email" value="<%= expediente.correo %>" required>
                        </div>
                        <div class="field-group full-width">
                            <label for="domicilio">Domicilio</label>
                            <textarea id="domicilio" name="domicilio" rows="2" required><%= expediente.domicilio %></textarea>
                        </div>
                    </div>

                    <!-- Persona Física -->
                    <div id="camposFisica" data-type="fisica">
                        <h3>Persona Física</h3>
                        <div class="form-grid">
                            <div class="field-group">
                                <label for="nombre">Nombre</label>
                                <input id="nombre" name="nombre" type="text" value="<%= expediente.nombre %>">
                            </div>
                            <div class="field-group">
                                <label for="apellido_paterno">Apellido paterno</label>
                                <input id="apellido_paterno" name="apellido_paterno" type="text" value="<%= expediente.apellido_paterno %>">
                            </div>
                            <div class="field-group">
                                <label for="apellido_materno">Apellido materno</label>
                                <input id="apellido_materno" name="apellido_materno" type="text" value="<%= expediente.apellido_materno %>">
                            </div>
                            <div class="field-group">
                                <label for="genero">Género</label>
                                <select id="genero" name="genero">
                                    <option value="" <%= !expediente.genero ? 'selected' : '' %>>Selecciona</option>
                                    <option value="masculino" <%= expediente.genero === 'masculino' ? 'selected' : '' %>>Masculino</option>
                                    <option value="femenino" <%= expediente.genero === 'femenino' ? 'selected' : '' %>>Femenino</option>
                                    <option value="otro" <%= expediente.genero === 'otro' ? 'selected' : '' %>>Otro</option>
                                </select>
                            </div>
                            <div class="field-group">
                                <label for="fecha_nacimiento">Fecha de nacimiento</label>
                                <input id="fecha_nacimiento" name="fecha_nacimiento" type="date" value="<%= expediente.fecha_nacimiento ? expediente.fecha_nacimiento.toISOString().substring(0,10) : '' %>">
                            </div>
                            <div class="field-group">
                                <label for="entidad_federativa_nacimiento">Entidad federativa de nacimiento</label>
                                <input id="entidad_federativa_nacimiento" name="entidad_federativa_nacimiento" type="text" value="<%= expediente.entidad_federativa_nacimiento %>">
                            </div>
                            <div class="field-group">
                                <label for="pais_nacimiento">País de nacimiento</label>
                                <input id="pais_nacimiento" name="pais_nacimiento" type="text" value="<%= expediente.pais_nacimiento %>">
                            </div>
                            <div class="field-group">
                                <label for="curp">CURP</label>
                                <input id="curp" name="curp" type="text" value="<%= expediente.curp %>">
                            </div>
                            <div class="field-group full-width">
                                <label for="ocupacion_actividad">Ocupación o actividad</label>
                                <textarea id="ocupacion_actividad" name="ocupacion_actividad" rows="2"><%= expediente.ocupacion_actividad %></textarea>
                            </div>
                            <div class="field-group">
                                <label for="rfc">RFC</label>
                                <input id="rfc" name="rfc" type="text" value="<%= expediente.rfc %>">
                            </div>
                            <div class="field-group">
                                <label for="numero_id_fiscal">Número de Identificación Fiscal</label>
                                <input id="numero_id_fiscal" name="numero_id_fiscal" type="text" value="<%= expediente.numero_id_fiscal %>">
                            </div>
                            <div class="field-group">
                                <label for="num_serie_firma">Número de serie de firma</label>
                                <input id="num_serie_firma" name="num_serie_firma" type="text" value="<%= expediente.num_serie_firma %>">
                            </div>
                        </div>
                    </div>

                    <!-- Persona Moral -->
                    <div id="camposMoral" data-type="moral">
                        <h3>Persona Moral</h3>
                        <div class="form-grid">
                            <div class="field-group">
                                <label for="razon_social">Razón social</label>
                                <input id="razon_social" name="razon_social" type="text" value="<%= expediente.razon_social %>">
                            </div>
                            <div class="field-group">
                                <label for="giro_mercantil_actividad">Giro mercantil / actividad</label>
                                <input id="giro_mercantil_actividad" name="giro_mercantil_actividad" type="text" value="<%= expediente.giro_mercantil_actividad %>">
                            </div>
                            <div class="field-group">
                                <label for="pais_asigna_id_fiscal">País que asigna ID fiscal</label>
                                <input id="pais_asigna_id_fiscal" name="pais_asigna_id_fiscal" type="text" value="<%= expediente.pais_asigna_id_fiscal %>">
                            </div>
                            <div class="field-group">
                                <label for="representante_legal">Representante legal</label>
                                <input id="representante_legal" name="representante_legal" type="text" value="<%= expediente.representante_legal %>">
                            </div>
                            <div class="field-group">
                                <label for="fecha_constitucion">Fecha de constitución</label>
                                <input id="fecha_constitucion" name="fecha_constitucion" type="date" value="<%= expediente.fecha_constitucion ? expediente.fecha_constitucion.toISOString().substring(0,10) : '' %>">
                            </div>
                            <div class="field-group">
                                <label for="rfc">RFC</label>
                                <input id="rfc" name="rfc" type="text" value="<%= expediente.rfc %>">
                            </div>
                            <div class="field-group">
                                <label for="numero_id_fiscal">Número de Identificación Fiscal</label>
                                <input id="numero_id_fiscal" name="numero_id_fiscal" type="text" value="<%= expediente.numero_id_fiscal %>">
                            </div>
                            <div class="field-group">
                                <label for="num_serie_firma">Número de serie de firma</label>
                                <input id="num_serie_firma" name="num_serie_firma" type="text" value="<%= expediente.num_serie_firma %>">
                            </div>
                        </div>
                            
                    </div>
                    <div class="form-actions">
                        <button class="submitButton" type="submit" onclick="return confirmarActualizacion(event)">Actualizar expediente</button>
                        <a class="secondaryButton" href="/oficial/Expediente">Cancelar</a>
                    </div>
          </form>
      </section>
  </div>
    
<%- include('./partials/script') %>
</body>
</html>
