<div class="main-content">
     <div class="header">
         <h2>Bitácora</h2>
     </div>
     <div class="content">
         <div class="card">
             <div class="card-body">
                 <h3>Bitácora del sistema</h3>
                 <p>Desde aquí puedes consultar las acciones registradas por los usuarios.</p>
             </div>
         </div>
     </div>

    <div class="alertas">
        <table border="1">
            <thead>
                <tr>
                    <th>ID Bitácora</th>
                    <th>ID Usuario</th>
                    <th>ID Alerta</th>
                    <th>Acción</th>
                    <th>Descripción</th>
                    <th>Fecha y Hora</th>
                </tr>
            </thead>
            <tbody>
                <% registros.forEach(reg => { %>
                    <tr>
                        <td><%= reg.id_bitacora %></td>
                        <td><%= reg.id_usuario %></td>
                        <td><%= reg.id_alerta %></td>
                        <td><%= reg.accion %></td>
                        <td><%= reg.descripcion %></td>
                        <td>
                            <%= new Date(reg.fecha_hora).toLocaleDateString('es-MX')%>
                            <%= new Date(reg.fecha_hora).toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' }) %>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="pager">
            <div style="margin: 1em; margin-left: 0;">
                <p class="meta">
                    <% if (registros.length > 0) { %>
                        Mostrando <%= registros.length %> de <%= total %> registros
                    <% } else { %>
                        No hay registros en la bitácora
                    <% } %>
                </p>
            </div>

            <% if (page > 1) { %>
                <a href="/oficial/Bitacora?page=<%= page - 1 %>">← Anterior</a>
            <% } %>

            <% for (let p = 1; p <= totalPages; p++) { %>
                <% if (p === page) { %>
                    <span class="current"><%= p %></span>
                <% } else { %>
                    <a href="/oficial/Bitacora?page=<%= p %>"><%= p %></a>
                <% } %>
            <% } %>

            <% if (page < totalPages) { %>
                <a href="/oficial/Bitacora?page=<%= page + 1 %>">Siguiente →</a>
            <% } %>
        </div>
    </div>
</div>