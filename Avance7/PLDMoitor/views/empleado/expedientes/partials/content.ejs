<div class="NuevoCliente">
    <form action="/empleado/expedientes/nuevo" method="get">
        <button class="NCButton" type="submit">
            <div class="plus">
                <i class="fa-solid fa-plus"></i>
            </div>
            Nuevo Cliente
        </button>
    </form>
</div>

<div class="main-content">
     <div class="header">
         <h2>Expedientes</h2>
     </div>
     <div class="content">
         <div class="card">
             <div class="card-body">
                 <p>Desde aquí puedes gestionar los expedientes.</p>
             </div>
         </div>
     </div>

    <div class="expedientes">
        <table border="1">
            <thead>
                <tr>
                    <th>ID Expediente</th>
                    <th>ID Cliente</th>
                    <th>Tipo Persona</th>
                    <th>Cliente</th>
                    <th>Tipo Expediente</th>
                    <th>Estatus</th>
                    <th>Fecha Apertura</th>
                    <th>Observaciones</th>
                </tr>
            </thead>
            <tbody>
                <% expedientes.forEach(exp => { %>
                    <tr>
                        <td><%= exp.id_expediente %></td>
                        <td><%= exp.cliente_id %></td>
                        <td><%= exp.tipo_persona %></td>

                        <td>
                            <% if (exp.tipo_persona === 'fisica') { %>
                                <%= exp.nombre %> <%= exp.apellido_paterno %> <%= exp.apellido_materno %>
                            <% } else { %>
                                <%= exp.razon_social %>
                            <% } %>
                        </td>

                        <td><%= exp.tipo_expediente %></td>
                        <td><%= exp.estatus_expediente %></td>
                        <td><%= exp.fecha_apertura %></td>
                        <td><%= exp.observaciones %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="pager">
            <div style="margin: 1em; margin-left: 0;"><p class="meta"><% if (expedientes.length > 0) { %>Mostrando <%= expedientes.length %> de <%= total %> expedientes<% } else { %>No hay expedientes disponibles<% } %></p></div>
            <% if (page > 1) { %>
                <a href="/empleado/Expedientes?page=<%= page - 1 %>">← Anterior</a>
            <% } %>
            <% for (let p = 1; p <= totalPages; p++) { %>
                <% if (p === page) { %>
                    <span class="current"><%= p %></span>
                <% } else { %>
                    <a href="/empleado/Expedientes?page=<%= p %>"><%= p %></a>
                <% } %>
            <% } %>
            <% if (page < totalPages) { %>
                <a href="/empleado/Expedientes?page=<%= page + 1 %>">Siguiente →</a>
            <% } %>
        </div>
    </div>