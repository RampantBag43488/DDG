<div class="main-content">
     <div class="header">
         <h2>Reportes</h2>
     </div>
     <div class="content">
         <div class="card">
             <div class="card-body">
                 <p>Desde aquí puedes gestionar los reportes.</p>
             </div>
         </div>
     </div>

    <div class="nuevoReporte">
      <h2>Nuevo Reporte</h2>

      <form>
            <div class="fila">
                <div>
                <label for="acusado">Nombre del acusado</label><br>
                <input type="text" id="acusado" name="acusado" placeholder="Nombre completo">
                </div>

                <br>

                <div>
                <label for="fecha">Fecha</label><br>
                <input type="date" id="fecha" name="fecha">
                </div>
            </div>
            <br>

            <div>
            <label for="descripcion">Descripción</label><br>
            <textarea id="descripcion" name="descripcion" rows="5" cols="40" placeholder="Describe los hechos..."></textarea>
            </div>

            <br>

            <div>
            <label for="archivo">Archivo adjunto</label><br>
            <input type="file" id="archivo" name="archivo">
            </div>

            <br>

            <button type="submit">Enviar reporte</button>
        </form>
    </div>

    <div class="reportes">
        <table border="1">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Acusado</th>
                    <th>Fecha de Generación</th>
                    <th>Descripción</th>
                    <th>Evidencia Adjunta</th>
                    <th>Estatus</th>
                    <th>Formato de Salida</th>
                </tr>
            </thead>
            <tbody>
                <% reportes.forEach(rep => { %>
                    <tr>
                        <td><%= rep.id_reporte %></td>
                        <td><%= rep.acusado %></td>
                        <td><%= rep.fecha_generacion %></td>
                        <td><%= rep.descripcion %></td>
                        <td><%= rep.evidencia_adjunta %></td>
                        <td><%= rep.estatus %></td>
                        <td><%= rep.formato_salida %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="pager">
            <div style="margin: 1em; margin-left: 0;"><p class="meta"><% if (reportes.length > 0) { %>Mostrando <%= reportes.length %> de <%= total %> reportes<% } else { %>No hay reportes disponibles<% } %></p></div>
            <% if (page > 1) { %>
                <a href="/empleado/Reportes?page=<%= page - 1 %>">← Anterior</a>
            <% } %>
            <% for (let p = 1; p <= totalPages; p++) { %>
                <% if (p === page) { %>
                    <span class="current"><%= p %></span>
                <% } else { %>
                    <a href="/empleado/Reportes?page=<%= p %>"><%= p %></a>
                <% } %>
            <% } %>
            <% if (page < totalPages) { %>
                <a href="/empleado/Reportes?page=<%= page + 1 %>">Siguiente →</a>
            <% } %>
        </div>
    </div>
 </div>