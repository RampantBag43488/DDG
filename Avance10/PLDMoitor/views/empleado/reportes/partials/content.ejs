<div class="main-content">
    <div class="header">
        <h2>Mensajes Anónimos</h2>
        <p>Desde aquí puedes enviar y consultar mensajes anónimos.</p>
    </div>

    <div class="nuevoReporte">
    <h2>Nuevo Mensaje Anónimo </h2>

    <form action="/empleado/Reportes" method="POST">
            <div class="fila">
                <div>
                <label for="acusado">Nombre del acusado</label><br>
                <input type="text" id="acusado" name="acusado" placeholder="Nombre completo" required>
                </div>

                <br>

                <div>
                <label for="fecha">Fecha</label><br>
                <input type="date" id="fecha" name="fecha" required>
                </div>
            </div>
            <br>

            <div>
            <label for="descripcion">Descripción</label><br>
            <textarea id="descripcion" name="descripcion" rows="5" cols="40" placeholder="Describe los hechos..." required></textarea>
            </div>

            <br>

            <div class="upload-area-container">
                <div class="upload-area" id="uploadArea">
                    <input type="file" id="archivo" name="archivo" class="file-input" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx">
                    <div class="upload-icon">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                    </div>
                    <div class="upload-text">
                        <span class="upload-title">Archivo adjunto</span>
                        <span class="upload-hint">Haz clic para seleccionar un archivo o arrástralo aquí</span>
                    </div>
                    <div class="file-info" id="fileInfo" style="display: none;">
                        <i class="fa-solid fa-file"></i>
                        <span class="file-name" id="fileName"></span>
                        <button type="button" class="file-remove" id="fileRemove" title="Eliminar archivo">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                </div>
            </div>

            <br>

            <button type="submit">Enviar mensaje</button>
        </form>
    </div>
        <script src="/js/reportesFiltro.js"></script>
        <script src="/js/alertasmensaje.js"></script>
        <script src="/js/uploadArea.js"></script>
    </div>
 </div>
