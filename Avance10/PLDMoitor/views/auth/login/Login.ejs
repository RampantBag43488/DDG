<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/auth/loginStyle.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

  <div class="card">
    <div class="logo-container">
      <img src="/img/logo.png" alt="Logo de la aplicación">
      <h2>Presentado por SVA LAW</h2>
      <h3 class="titulo">PLD MONITOR</h3>
      <p class="subtitulo"> Monitoreo de operaciones </p>

    <h1>Iniciar sesión</h1>

    </div>
        <% if (error === 'usuario') { %>
      <p class="error-message">
        El usuario no existe
      </p>
    <% } %>

    <% if (error === 'password') { %>
      <p class="error-message">
        Contraseña incorrecta
      </p>
    <% } %>

    <% if (error === 'inactivo') { %>
      <p class="error-message">
        Usuario inactivo
      </p>
    <% } %>
    <form action="/login" method="POST">
        <input type="text" name="usuario" placeholder="Id_usuario" required>
        <div class="password-container">
          <input type="password" name="password" placeholder="Contraseña" required>
          <button type="button" class="password-toggle" aria-label="Mostrar contraseña" title="Mostrar contraseña">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
        <button type="submit">Ingresar</button>
    </form>
  </div>

  <script src="/js/loginPasswordToggle.js"></script>
</body>
</html>
