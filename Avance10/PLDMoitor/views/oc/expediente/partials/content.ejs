<div class="NuevoCliente">
    <form action="/oficial/Expediente/Nuevo" method="get">
        <button class="NCButton" type="submit">
            <div class="plus">
                <i class="fa-solid fa-plus"></i>
            </div>
            Nuevo Cliente
        </button>
    </form>
</div>


<div class="main-content">
     <div class="header">
         <h2>Expedientes</h2>
         <p>Bienvenido, Oficial de Cumplimiento. Desde aquí puedes gestionar los expedientes.</p>
     </div>

     <div class="NC">
        <div class="NuevoCliente">
    <form action="/oficial/Expediente/Nuevo" method="get">
        <button class="NCButton" type="submit">
            <div class="plus">
                <i class="fa-solid fa-plus"></i>
            </div>
            Nuevo Cliente
        </button>
    </form>
</div>
     </div>

    <div class="expedientes">
        <table border="1">
            <thead>
                <tr>
                    <th>ID Expediente</th>
                    <th>ID Cliente</th>
                    <th>Tipo Persona</th>
                    <th>Cliente</th>
                    <th>Tipo Expediente</th>
                    <th>Estatus</th>
                    <th>Fecha Apertura</th>
                    <th>Observaciones</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% expedientes.forEach(exp => { %>
                    <tr>
                        <td><%= exp.id_expediente %></td>
                        <td><%= exp.cliente_id %></td>
                        <td><%= exp.tipo_persona %></td>

                        <td>
                            <% if (exp.tipo_persona === 'fisica') { %>
                                <%= exp.nombre %> <%= exp.apellido_paterno %> <%= exp.apellido_materno %>
                            <% } else { %>
                                <%= exp.razon_social %>
                            <% } %>
                        </td>

                        <td><%= exp.tipo_expediente %></td>
                        <td><%= exp.estatus_expediente %></td>
                        <td><%= new Date(exp.fecha_apertura).toLocaleDateString('es-MX') %></td>
                        <td><%= exp.observaciones %></td>
                        <td style="text-align: center;">
                            <form action="/oficial/Expediente/Actualizar" method="get" style="margin:0;">
                                <input type="hidden" name="id_expediente" value="<%= exp.id_expediente %>" />
                                <button type="submit" class="actionButton">Ver expediente</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
        <div class="pager">
            <div style="margin: 1em; margin-left: 0;"><p class="meta"><% if (expedientes.length > 0) { %>Mostrando <%= expedientes.length %> de <%= total %> expedientes<% } else { %>No hay expedientes disponibles<% } %></p></div>
            <% if (page > 1) { %>
                <a href="/oficial/Expediente?page=<%= page - 1 %>">← Anterior</a>
            <% } %>
            <% for (let p = 1; p <= totalPages; p++) { %>
                <% if (p === page) { %>
                    <span class="current"><%= p %></span>
                <% } else { %>
                    <a href="/oficial/Expediente?page=<%= p %>"><%= p %></a>
                <% } %>
            <% } %>
            <% if (page < totalPages) { %>
                <a href="/oficial/Expediente?page=<%= page + 1 %>">Siguiente →</a>
            <% } %>
        </div>
    </div>
 </div>