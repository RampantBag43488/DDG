<div class="bar">
    <div id="sidebar" class="sidebar no-transition">
        <div class="content">
            <div class="sidebar-header">
                <div class="logo">
                    <img src="/img/OClogo.jpg" alt="logo">
                    <h4>Oficial de Cumplimiento</h4>
                </div>

                <div id="arrow" class="arrow"><i class="fa-solid fa-caret-left"></i></div>
                
            </div>

            <nav class="menu">
                <ul>
                    <li>
                        <a class="selected" href="/oficial/Dashboard">
                            <i class="fa-solid fa-house"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <li>
                        <a href="/oficial/Alertas">
                            <i class="fa-solid fa-bell"></i>
                            <span>Alertas</span>
                        </a>
                    </li>

                    <li>
                        <a href="/oficial/Clientes">
                            <i class="fa-solid fa-users"></i>
                            <span>Clientes</span>
                        </a>
                    </li>

                    <li>
                        <a href="/oficial/Reportes">
                            <i class="fa-solid fa-align-right"></i>
                            <span>Mensajes Anónimos</span>
                        </a>
                    </li>

                    <li>
                        <a href="/oficial/Operaciones">
                            <i class="fa-solid fa-money-bill-transfer"></i>
                            <span>Operaciones</span>
                        </a>
                    </li>

                    <li>
                        <a href="/oficial/Expediente">
                            <i class="fa-solid fa-person-circle-plus"></i>
                            <span>Expediente</span>
                        </a>
                    </li>

                    <li>
                        <a href="/oficial/Bitacora">
                            <i class="fa-solid fa-clock-rotate-left"></i>
                            <span>Bitácora</span>
                        </a>
                    </li>

                    <li>
                        <a href="/oficial/Productos">
                            <i class="fa-solid fa-box"></i>
                            <span>Productos</span>
                        </a>
                    </li>
                </ul>
            </nav>
            
            <div class="user">
                <div>
                <img src="/img/OClogo.jpg" alt="user">
                </div>

                <div class="user-info">
                    <h5><%= typeof usuario !== 'undefined' && usuario.nombre ? usuario.nombre + ' ' + (usuario.apellido_paterno || '') + ' ' + (usuario.apellido_materno || '') : 'Usuario' %></h5>
                    <p><%= typeof usuario !== 'undefined' && usuario.email ? usuario.email : '' %></p>
                </div>

                <div id="arrow_down" class="arrow_down"><i class="fa-solid fa-sort-down"></i></div>
            </div>
        </div>
    </div>
</div>
<script>
    // Script en línea para restaurar el estado del sidebar antes de renderizar
    // Esto previene el parpadeo aplicando el estado antes de la primera pintura
    (function() {
        var sidebarState = localStorage.getItem('sidebar');
        var sidebar = document.getElementById('sidebar');
        if (sidebarState === 'hidden' && sidebar) {
            sidebar.classList.add('hide');
            // Establece el margen inicial para main-content y previene saltos de diseño
            document.documentElement.style.setProperty('--sidebar-width', '80px');
        } else {
            document.documentElement.style.setProperty('--sidebar-width', '220px');
        }
    })();
</script>
