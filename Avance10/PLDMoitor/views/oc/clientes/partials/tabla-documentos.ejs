<div class="tabla-documentos">
  <% if (documentos.length === 0) { %>
    <p>Este cliente no ha subido documentos aún.</p>
  <% } else { %>
    <table border="1">
      <thead>
        <tr>
          <th>Tipo de Documento</th>
          <th>Nombre del Archivo</th>
          <th>Fecha de Carga</th>
          <th>Estatus</th>
          <th>Acción</th>
        </tr>
      </thead>
      <tbody>
        <% documentos.forEach(doc => { %>
          <tr>
            <td><%= doc.tipo_documento %></td>
            <td><%= doc.nombre_archivo %></td>
            <td><%= new Date(doc.fecha_carga).toLocaleDateString('es-MX') %></td>
            <td><%= doc.estatus %></td>
            <td>
              <a href="/oficial/documentos/<%= doc.id_documento %>/signed-url" target="_blank" class="btn-consultar">Ver documento</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>