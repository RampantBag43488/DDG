<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/oficial/ClientesOC.css">
    <link rel="stylesheet" href="/css/oficial/sidebarOC.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <%- include('./components/sidebar') %>

    <div class="main-content">
        <div class="volver-container">
        <form action="/oficial/Clientes/consulta/<%= cliente.cliente_id %>?tab=contratos" method="get">
            <button class="VolverButton" type="submit">
            <div class="plus">
                <i class="fa-solid fa-arrow-left"></i>
            </div>
            Volver
            </button>
        </form>
        </div>

        <div class="form-card">
        <h2>Registrar contrato</h2>
        <p>Captura la información del nuevo contrato para este cliente.</p>

        <form action="/oficial/Clientes/consulta/<%= cliente.cliente_id %>/contratos/nuevo" method="POST">
            <div class="form-grid">
            <div class="grupo-form">
                <label for="id_producto">Producto</label>
                <select id="id_producto" name="id_producto" required>
                <option value="">Selecciona un producto</option>
                <% productos.forEach(producto => { %>
                    <option value="<%= producto.id_producto %>">
                    <%= producto.nombre_producto %> - <%= producto.tipo_producto %>
                    </option>
                <% }) %>
                </select>
            </div>

            <div class="grupo-form">
                <label for="tipo_contrato">Tipo de contrato</label>
                <input type="text" id="tipo_contrato" name="tipo_contrato" placeholder="Ej. Inversión, Personal, Empresarial, etc." required>
            </div>

            <div class="grupo-form">
                <label for="folio_contrato">Folio del contrato</label>
                <input type="text" id="folio_contrato" name="folio_contrato" placeholder="FOL-Año-Num" required>
            </div>

            <div class="grupo-form">
                <label for="fecha_firma">Fecha de firma</label>
                <input type="datetime-local" id="fecha_firma" name="fecha_firma" required>
            </div>

            <div class="grupo-form">
                <label for="fecha_inicio">Fecha de inicio</label>
                <input type="date" id="fecha_inicio" name="fecha_inicio" required>
            </div>

            <div class="grupo-form">
                <label for="fecha_final">Fecha final</label>
                <input type="date" id="fecha_final" name="fecha_final" required>
            </div>

            <div class="grupo-form">
                <label for="monto_autorizado">Monto autorizado</label>
                <input type="number" id="monto_autorizado" name="monto_autorizado" min="0.01" step="0.01" required>
            </div>

            <div class="grupo-form">
                <label for="estatus_contrato">Estatus</label>
                <select id="estatus_contrato" name="estatus_contrato" required>
                <option value="">Selecciona un estatus</option>
                <option value="vigente">Vigente</option>
                <option value="vencido">Vencido</option>
                <option value="cancelado">Cancelado</option>
                <option value="en revision">En revisión</option>
                </select>
            </div>

            <div class="grupo-form full-width">
                <label for="observaciones">Observaciones</label>
                <textarea id="observaciones" name="observaciones" rows="3"></textarea>
            </div>
            </div>

            <div class="form-actions">
            <button class="submitButton" type="submit">Guardar contrato</button>
            </div>
        </form>
        </div>
    </div>

    <script src="/js/Sidebar.js"></script>
</body>
</html>