<div class="main-content">
     <div class="header">
         <h2>Bitácora</h2>
         <p>Bitácora del sistema. Desde aquí puedes consultar las acciones registradas por los usuarios.</p>
     </div>

    <div class="alertas">
        <table border="1">
            <thead>
                <tr>
                    <th>ID Bitácora</th>
                    <th>ID Usuario</th>
                    <th>ID Alerta</th>
                    <th>Acción</th>
                    <th>Descripción</th>
                    <th>Fecha y Hora</th>
                </tr>
            </thead>
            <tbody>
                <% registros.forEach(reg => { %>
                    <tr>
                        <td><%= reg.id_bitacora %></td>
                        <td><%= reg.id_usuario %></td>
                        <td><%= reg.id_alerta %></td>
                        <td><%= reg.accion %></td>
                        <td><%= reg.descripcion %></td>
                        <td>
                            <%= new Date(reg.fecha_hora).toLocaleDateString('es-MX')%>
                            <%= new Date(reg.fecha_hora).toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' }) %>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="pager">
            <div style="margin: 1em; margin-left: 0;">
                <p class="meta">
                    <% if (registros.length > 0) { %>
                        Mostrando <%= registros.length %> de <%= total %> registros
                    <% } else { %>
                        No hay registros en la bitácora
                    <% } %>
                </p>
            </div>

            <%
            // Paginación condensada con elipsis
            // Genera un array de elementos a mostrar: números de página o '...'
            var pagerItems = [];

            if (totalPages <= 7) {
                // Si hay 7 o menos páginas, mostrar todas
                for (var p = 1; p <= totalPages; p++) {
                    pagerItems.push({ type: 'page', num: p });
                }
            } else {
                // Siempre mostrar primera página
                pagerItems.push({ type: 'page', num: 1 });

                if (page <= 3) {
                    // Páginas iniciales (1-4): mostrar 1, 2, 3, 4, ..., last
                    pagerItems.push({ type: 'page', num: 2 });
                    pagerItems.push({ type: 'page', num: 3 });
                    pagerItems.push({ type: 'page', num: 4 });
                    pagerItems.push({ type: 'ellipsis' });
                    pagerItems.push({ type: 'page', num: totalPages });
                } else if (page >= totalPages - 2) {
                    // Páginas finales: mostrar 1, ..., last-3, last-2, last-1, last
                    pagerItems.push({ type: 'ellipsis' });
                    pagerItems.push({ type: 'page', num: totalPages - 3 });
                    pagerItems.push({ type: 'page', num: totalPages - 2 });
                    pagerItems.push({ type: 'page', num: totalPages - 1 });
                    pagerItems.push({ type: 'page', num: totalPages });
                } else {
                    // Páginas centrales: mostrar 1, ..., page-1, page, page+1, ..., last
                    pagerItems.push({ type: 'ellipsis' });
                    pagerItems.push({ type: 'page', num: page - 1 });
                    pagerItems.push({ type: 'page', num: page });
                    pagerItems.push({ type: 'page', num: page + 1 });
                    pagerItems.push({ type: 'ellipsis' });
                    pagerItems.push({ type: 'page', num: totalPages });
                }
            }
            %>

            <% pagerItems.forEach(function(item) { %>
                <% if (item.type === 'ellipsis') { %>
                    <span class="ellipsis">...</span>
                <% } else if (item.num === page) { %>
                    <span class="current"><%= item.num %></span>
                <% } else { %>
                    <a href="/oficial/Bitacora?page=<%= item.num %>"><%= item.num %></a>
                <% } %>
            <% }); %>
        </div>
    </div>
</div>