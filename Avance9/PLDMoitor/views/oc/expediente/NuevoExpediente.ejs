<!DOCTYPE HTML>
<html>
<head>
  <%- include('./partials/css') %>
</head>

<body>
  <%- include('./components/sidebar') %>

  <div class="main-content">
    <div class="page-top">
      <div>
        <h1>Nuevo Expediente</h1>
        <p class="subtitle">Captura los datos del cliente con el tipo de persona correcto.</p>
      </div>

      <form action="/oficial/Expediente" method="get">
        <button class="VolverButton" type="submit">
          <div class="plus">
            <i class="fa-solid fa-arrow-left"></i>
          </div>
          Volver
        </button>
      </form>
    </div>

    <section class="form-card">
      <form id="expedienteForm" action="/oficial/Expediente/Nuevo" method="POST">

        <div class="form-header">
          <div>
            <h2>Datos del cliente</h2>
            <p>Selecciona el tipo de persona y completa los campos obligatorios.</p>
          </div>

          <div class="field-group select-group">
            <label for="tipoPersona">Tipo de Persona</label>
            <select id="tipoPersona" name="tipoPersona" required>
              <option value="fisica" selected>Persona Física</option>
              <option value="moral">Persona Moral</option>
            </select>
          </div>
        </div>

        <h3>Datos comunes</h3>

        <div class="form-grid">
          <div class="field-group">
            <label for="nacionalidad">Nacionalidad</label>
            <input id="nacionalidad" name="nacionalidad" type="text" placeholder="Ej. Mexicana" required>
          </div>

          <div class="field-group">
            <label for="rfc">RFC</label>
            <input id="rfc" name="rfc" type="text" placeholder="RFC" required>
          </div>

          <div class="field-group">
            <label for="numero_id_fiscal">Número de Identificación Fiscal</label>
            <input id="numero_id_fiscal" name="numero_id_fiscal" type="text" placeholder="ID fiscal" required>
          </div>

          <div class="field-group">
            <label for="num_serie_firma">Número de serie de firma</label>
            <input id="num_serie_firma" name="num_serie_firma" type="text" placeholder="Serie de firma" required>
          </div>

          <div class="field-group">
            <label for="telefono">Teléfono</label>
            <input id="telefono" name="telefono" type="tel" placeholder="5512345678" required>
          </div>

          <div class="field-group">
            <label for="correo">Correo</label>
            <input id="correo" name="correo" type="email" placeholder="correo@dominio.com" required>
          </div>

          <div class="field-group full-width">
            <label for="domicilio">Domicilio</label>
            <textarea id="domicilio" name="domicilio" rows="2" placeholder="Calle, número, colonia, ciudad" required></textarea>
          </div>
        </div>

        <div id="camposFisica" data-type="fisica">
          <h3>Persona Física</h3>

          <div class="form-grid">
            <div class="field-group">
              <label for="nombre">Nombre</label>
              <input id="nombre" name="nombre" type="text" placeholder="Nombre">
            </div>

            <div class="field-group">
              <label for="apellido_paterno">Apellido paterno</label>
              <input id="apellido_paterno" name="apellido_paterno" type="text" placeholder="Apellido paterno">
            </div>

            <div class="field-group">
              <label for="apellido_materno">Apellido materno</label>
              <input id="apellido_materno" name="apellido_materno" type="text" placeholder="Apellido materno">
            </div>

            <div class="field-group">
              <label for="genero">Género</label>
              <select id="genero" name="genero">
                <option value="">Selecciona</option>
                <option value="masculino">Masculino</option>
                <option value="femenino">Femenino</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <div class="field-group">
              <label for="fecha_nacimiento">Fecha de nacimiento</label>
              <input id="fecha_nacimiento" name="fecha_nacimiento" type="date">
            </div>

            <div class="field-group">
              <label for="entidad_federativa_nacimiento">Entidad federativa de nacimiento</label>
              <input id="entidad_federativa_nacimiento" name="entidad_federativa_nacimiento" type="text" placeholder="Ej. Querétaro">
            </div>

            <div class="field-group">
              <label for="pais_nacimiento">País de nacimiento</label>
              <input id="pais_nacimiento" name="pais_nacimiento" type="text" placeholder="Ej. México">
            </div>

            <div class="field-group">
              <label for="curp">CURP</label>
              <input id="curp" name="curp" type="text" placeholder="CURP">
            </div>

            <div class="field-group full-width">
              <label for="ocupacion_actividad">Ocupación o actividad</label>
              <textarea id="ocupacion_actividad" name="ocupacion_actividad" rows="2" placeholder="Describe la ocupación o actividad"></textarea>
            </div>
          </div>
        </div>

        <div id="camposMoral" data-type="moral" style="display: none;">
          <h3>Persona Moral</h3>

          <div class="form-grid">
            <div class="field-group">
              <label for="razon_social">Razón social</label>
              <input id="razon_social" name="razon_social" type="text" placeholder="Razón social">
            </div>

            <div class="field-group">
              <label for="giro_mercantil_actividad">Giro mercantil / actividad</label>
              <input id="giro_mercantil_actividad" name="giro_mercantil_actividad" type="text" placeholder="Giro mercantil">
            </div>

            <div class="field-group">
              <label for="pais_asigna_id_fiscal">País que asigna ID fiscal</label>
              <input id="pais_asigna_id_fiscal" name="pais_asigna_id_fiscal" type="text" placeholder="Ej. México">
            </div>

            <div class="field-group">
              <label for="representante_legal">Representante legal</label>
              <input id="representante_legal" name="representante_legal" type="text" placeholder="Nombre del representante">
            </div>

            <div class="field-group">
              <label for="fecha_constitucion">Fecha de constitución</label>
              <input id="fecha_constitucion" name="fecha_constitucion" type="date">
            </div>
          </div>
        </div>

        <h3>Datos del expediente</h3>

        <div class="form-grid">
          <div class="field-group">
            <label for="tipo_expediente">Tipo de expediente</label>
            <select id="tipo_expediente" name="tipo_expediente" required>
              <option value="">Selecciona</option>
              <option value="apertura">Apertura</option>
              <option value="actualizacion">Actualización</option>
              <option value="revision">Revisión</option>
            </select>
          </div>

          <div class="field-group">
            <label for="estatus_expediente">Estatus</label>
            <select id="estatus_expediente" name="estatus_expediente" required>
              <option value="en_revision" selected>En Revision</option>
              <option value="aprobado">Aprobado</option>
              <option value="rechazado">Rechazado</option>
              <option value ="cerrado">Cerrado</option>
            </select>
          </div>

          <div class="field-group full-width">
            <label for="observaciones">Observaciones</label>
            <textarea id="observaciones" name="observaciones" rows="2" placeholder="Observaciones del expediente"></textarea>
          </div>
        </div>

        <div class="form-actions">
          <button class="submitButton" type="submit">Guardar expediente</button>

          <button
            class="secondaryButton"
            type="button"
            onclick="window.location.href='/oficial/Expediente'">
            Cancelar
          </button>
        </div>

      </form>
    </section>
  </div>

  <%- include('./partials/script') %>
</body>
</html>