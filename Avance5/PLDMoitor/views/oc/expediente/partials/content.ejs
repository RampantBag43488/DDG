<div class="main-content">
     <div class="header">
         <h2>Expedientes</h2>
     </div>
     <div class="content">
         <div class="card">
             <div class="card-body">
                 <h3>Bienvenido, Oficial de Cumplimiento</h3>
                 <p>Desde aquí puedes gestionar los expedientes.</p>
             </div>
         </div>
     </div>

    <div class="expedientes">
        <table border="1">
            <thead>
                <tr>
                    <th>ID Expediente</th>
                    <th>ID Cliente</th>
                    <th>Actividad</th>
                    <th>Nombre</th>
                    <th>Apellido Paterno</th>
                    <th>Apellido Materno</th>
                    <th>Nacionalidad</th>
                    <th>Fecha Nacimiento</th>
                    <th>RFC</th>
                    <th>Correo</th>
                    <th>Telefono</th>
                    <th>Domicilio</th>
                    <th>Numero ID Fiscal</th>
                    <th>Numero Serie Firma</th>
                </tr>
            </thead>
            <tbody>
                <% expedientes.forEach(exp => { %>
                    <tr>
                        <td><%= exp.id_expediente %></td>
                        <td><%= exp.cliente_id %></td>
                        <td><%= exp.actividad %></td>
                        <td><%= exp.nombre %></td>
                        <td><%= exp.apellido_paterno %></td>
                        <td><%= exp.apellido_materno %></td>
                        <td><%= exp.nacionalidad %></td>
                        <td><%= exp.fecha_nacimiento %></td>
                        <td><%= exp.rfc %></td>
                        <td><%= exp.correo %></td>
                        <td><%= exp.telefono %></td>
                        <td><%= exp.domicilio %></td>
                        <td><%= exp.numero_id_fiscal %></td>
                        <td><%= exp.num_serie_firma %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="pager">
            <div style="margin: 1em; margin-left: 0;"><p class="meta"><% if (expedientes.length > 0) { %>Mostrando <%= expedientes.length %> de <%= total %> expedientes<% } else { %>No hay expedientes disponibles<% } %></p></div>
            <% if (page > 1) { %>
                <a href="/oficial/Expediente?page=<%= page - 1 %>">← Anterior</a>
            <% } %>
            <% for (let p = 1; p <= totalPages; p++) { %>
                <% if (p === page) { %>
                    <span class="current"><%= p %></span>
                <% } else { %>
                    <a href="/oficial/Expediente?page=<%= p %>"><%= p %></a>
                <% } %>
            <% } %>
            <% if (page < totalPages) { %>
                <a href="/oficial/Expediente?page=<%= page + 1 %>">Siguiente →</a>
            <% } %>
        </div>
    </div>
 </div>